# Copy this file to .env and fill in real values. NEVER commit .env to version control.

# Django
SECRET_KEY=replace-with-a-long-random-value-never-reuse-this
DEBUG=False
ALLOWED_HOSTS=127.0.0.1,localhost,yourdomain.com

# Encrypts PII at rest (address, phone, birthday, shipping details).
# The value below is a working DEV-ONLY example key so this runs out of
# the box — generate your own before using this for anything real:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# Changing this key after data exists makes that data unreadable — back up
# before rotating in production.
FIELD_ENCRYPTION_KEY=YZbLOmookh6284ZfHtO3AXYjBIjXJMbSFTT72gXEF14=

# Database (defaults to SQLite for dev; use Postgres in production)
DATABASE_URL=sqlite:///db.sqlite3

# PayMongo — GCash & Maya (get test keys from https://dashboard.paymongo.com/developers)
PAYMONGO_PUBLIC_KEY=pk_test_xxxxxxxxxxxx
PAYMONGO_SECRET_KEY=sk_test_xxxxxxxxxxxx
PAYMONGO_WEBHOOK_SECRET=whsk_xxxxxxxxxxxx

# PayPal (get sandbox credentials from https://developer.paypal.com/dashboard/applications/sandbox)
PAYPAL_CLIENT_ID=xxxxxxxxxxxx
PAYPAL_CLIENT_SECRET=xxxxxxxxxxxx
PAYPAL_MODE=sandbox

# Security
# Leave these unset to let settings.py default them to `not DEBUG` (i.e.
# automatically secure in production, relaxed for local HTTP development).
# Only set explicitly if you need to override that default.
# SESSION_COOKIE_SECURE=True
# CSRF_COOKIE_SECURE=True
